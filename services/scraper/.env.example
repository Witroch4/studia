# ─── Scraper runtime ─────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO

# ─── TecConcursos auth (origem) ──────────────────────────────────
TC_BASE=https://www.tecconcursos.com.br
TC_EMAIL=
TC_PASSWORD=
TC_STORAGE_STATE_PATH=./storage_state.json
TC_RATE_PER_SEC=2.0
TC_MAX_CONCURRENCY=4

# ─── User-Agent realista ─────────────────────────────────────────
TC_USER_AGENT=Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/126.0.0.0 Safari/537.36

# ─── Persistência (destino) ──────────────────────────────────────
# DSN do Postgres do studia. Em compose: postgres:5432, fora: localhost:5433
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/studia

# Diretório para state de retomada e dumps raw
SCRAPE_STATE_PATH=./scrape_state.db
DISCOVERY_DUMP_DIR=./discovery

# ─── Futuro: integração com platform-api (extração para monorepo) ──
# BACKEND_URL=http://platform-api:8000
# PLATFORM_API_KEY=
